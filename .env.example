# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,my-app.run.app

# Database (for Cloud SQL, use private IP or Cloud SQL proxy socket)
# Option 1: Private IP connection
# DATABASE_URL=postgresql://tandem_user:tandem_password@10.x.x.x:5432/tandem_db

# Option 2: Cloud SQL proxy socket (recommended)
# DATABASE_URL=postgresql:///tandem_db?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME

# For local development with docker-compose:
DATABASE_URL=postgresql://tandem_user:tandem_password@localhost:5432/tandem_db
